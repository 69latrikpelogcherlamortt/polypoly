# ════════════════════════════════════════════════════════════
#  PAF-001 — Fichier de configuration (.env)
#  Copier ce fichier en ".env" et remplir les valeurs
# ════════════════════════════════════════════════════════════

# ── MODE ──────────────────────────────────────────────────────────────────
# true  = paper trading (RECOMMANDÉ pour commencer)
# false = live trading (argent réel — ATTENTION)
DRY_RUN=true

# ── POLYMARKET CREDENTIALS ────────────────────────────────────────────────
# Obtenir via https://docs.polymarket.com/#authentication
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Clé privée du wallet Polygon (hex, sans 0x)
# ⚠  Ne jamais committer ce fichier avec la clé remplie
POLY_PRIVATE_KEY=
POLY_WALLET_ADDRESS=

# ── CAPITAL ───────────────────────────────────────────────────────────────
INITIAL_BANKROLL=100.0

# ── APIS OPTIONNELLES ────────────────────────────────────────────────────
# BLS.gov — données CPI/emploi (inscription gratuite sur bls.gov)
BLS_API_KEY=

# Wallet de référence à surveiller (whale tracking)
REFERENCE_WALLET=

# ── TELEGRAM ALERTES ─────────────────────────────────────────────────────
# Créer un bot via @BotFather, puis obtenir le chat_id via @userinfobot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── PERSISTANCE ──────────────────────────────────────────────────────────
DB_PATH=paf_trading.db
SIGNAL_DB_PATH=paf_signals.db

# ════════════════════════════════════════════════════════════
# CHECKLIST AVANT LIVE TRADING :
# ─────────────────────────────
# □ DRY_RUN=true au moins 2 semaines de paper trading
# □ Brier Score < 0.20 sur 15+ résolutions en paper trading
# □ Toutes les credentials testées en DRY_RUN=true
# □ Telegram configuré pour recevoir les alertes
# □ Bankroll limitée à 100€ pour la phase de calibration
# □ Kill switches vérifiés (bankroll < 60€ → arrêt auto)
# ════════════════════════════════════════════════════════════
