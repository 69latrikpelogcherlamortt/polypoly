# ══════════════════════════════════════════════════════════════
# PAF-001 — .gitignore
# ══════════════════════════════════════════════════════════════

# Secrets & credentials
.env
.env.*
!.env.example
*.pem
*.key
*.p12
.emergency_stop

# Databases
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# Backups
backups/

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# OS
.DS_Store
Thumbs.db

# py.typed marker (keep in repo)
!py.typed
